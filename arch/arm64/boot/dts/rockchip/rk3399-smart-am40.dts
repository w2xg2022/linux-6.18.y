// SPDX-License-Identifier: (GPL-2.0+ OR MIT)

/dts-v1/;

#include <dt-bindings/input/linux-event-codes.h>
#include <dt-bindings/leds/common.h>
#include <dt-bindings/pwm/pwm.h>
#include "rk3399.dtsi"

/ {
	model = "Theobroma am40";
	compatible = "turquoise,rk3399-smart-am40", "rockchip,rk3399";

	aliases {
		ethernet0 = &gmac;
		i2c0 = &i2c0;
		i2c1 = &i2c1;
		i2c2 = &i2c2;
		i2c3 = &i2c3;
		i2c4 = &i2c4;
		i2c5 = &i2c5;
		i2c6 = &i2c6;
		i2c7 = &i2c7;
		i2c8 = &i2c8;
		serial0 = &uart0;
		serial1 = &uart1;
		serial2 = &uart2;
		serial3 = &uart3;
		serial4 = &uart4;
		mmc0 = &sdhci;
		mmc1 = &sdmmc;
	};

	chosen {
		stdout-path = "serial0:115200n8";
	};

	clkin_gmac: external-gmac-clock {
		compatible = "fixed-clock";
		clock-frequency = <125000000>;
		clock-output-names = "clkin_gmac";
		#clock-cells = <0>;
	};

	dc_12v: regulator-dc-12v {
		compatible = "regulator-fixed";
		regulator-name = "dc_12v";
		regulator-always-on;
		regulator-boot-on;
		regulator-min-microvolt = <12000000>;
		regulator-max-microvolt = <12000000>;
	};

	vcc5v0_sys: regulator-vcc5v0-sys {
		compatible = "regulator-fixed";
		regulator-name = "vcc5v0_sys";
		regulator-always-on;
		regulator-boot-on;
		regulator-min-microvolt = <5000000>;
		regulator-max-microvolt = <5000000>;
	};

	vcc_sys: regulator-vcc-sys {
		compatible = "regulator-fixed";
		regulator-name = "vcc_sys";
		regulator-always-on;
		regulator-boot-on;
		regulator-min-microvolt = <5000000>;
		regulator-max-microvolt = <5000000>;
	};

	vcc3v3_sys: regulator-vcc3v3-sys {
		compatible = "regulator-fixed";
		regulator-name = "vcc3v3_sys";
		regulator-always-on;
		regulator-boot-on;
		regulator-min-microvolt = <3300000>;
		regulator-max-microvolt = <3300000>;
		vin-supply = <&vcc_sys>;
	};

	vcc3v3_baseboard: regulator-vcc3v3-baseboard {
		compatible = "regulator-fixed";
		regulator-name = "vcc3v3_baseboard";
		regulator-always-on;
		regulator-boot-on;
		regulator-min-microvolt = <3300000>;
		regulator-max-microvolt = <3300000>;
		vin-supply = <&dc_12v>;
	};

	vcc5v0_baseboard: regulator-vcc5v0-baseboard {
		compatible = "regulator-fixed";
		regulator-name = "vcc5v0_baseboard";
		regulator-always-on;
		regulator-boot-on;
		regulator-min-microvolt = <5000000>;
		regulator-max-microvolt = <5000000>;
		vin-supply = <&dc_12v>;
	};

	/*
	 * vcc1v2_phy powers the GMAC PHY analog core.
	 * gpio1 RK_PB5 (pin 13) = eth-phy-pwr from decompiled pinctrl.
	 */
	vcc1v2_phy: regulator-vcc1v2-phy {
		compatible = "regulator-fixed";
		enable-active-high;
		gpio = <&gpio1 RK_PB5 GPIO_ACTIVE_HIGH>;
		pinctrl-names = "default";
		pinctrl-0 = <&eth_phy_pwr>;
		regulator-name = "vcc1v2_phy";
		regulator-always-on;
		regulator-boot-on;
		regulator-min-microvolt = <1200000>;
		regulator-max-microvolt = <1200000>;
		vin-supply = <&vcc_sys>;
	};

	/*
	 * vcc5v0_host powers USB2 EHCI/OHCI host ports.
	 * gpio1 RK_PA3 (pin 3) = vcc5v0-host-en.
	 */
	vcc5v0_host: regulator-vcc5v0-host {
		compatible = "regulator-fixed";
		enable-active-high;
		gpio = <&gpio1 RK_PA3 GPIO_ACTIVE_HIGH>;
		pinctrl-names = "default";
		pinctrl-0 = <&vcc5v0_host_en>;
		regulator-name = "vcc5v0_host";
		regulator-always-on;
		vin-supply = <&vcc5v0_sys>;
	};

	/*
	 * vcc3v3_pcie powers the PCIe bus (RTL8822BE WiFi card).
	 * gpio1 RK_PA4 (pin 4) = pcie-drv from decompiled pinctrl.
	 */
	vcc3v3_pcie: regulator-vcc3v3-pcie {
		compatible = "regulator-fixed";
		enable-active-high;
		gpio = <&gpio1 RK_PA4 GPIO_ACTIVE_HIGH>;
		pinctrl-names = "default";
		pinctrl-0 = <&pcie_drv>;
		regulator-always-on;
		regulator-boot-on;
		regulator-name = "vcc3v3_pcie";
	};

	/*
	 * vcc5v0_hdmi controls the HDMI 5V supply.
	 * gpio4 RK_PD4 (pin 28) = hdmi-5v-drv from decompiled pinctrl.
	 */
	vcc5v0_hdmi: regulator-vcc5v0-hdmi {
		compatible = "regulator-fixed";
		enable-active-high;
		gpio = <&gpio4 RK_PD4 GPIO_ACTIVE_HIGH>;
		pinctrl-names = "default";
		pinctrl-0 = <&hdmi_5v_drv>;
		regulator-name = "hdmi_5v";
		regulator-always-on;
		regulator-boot-on;
	};

	vcc3v3_dp: regulator-vcc3v3-dp {
		compatible = "regulator-fixed";
		regulator-name = "vcc3v3_dp";
		regulator-always-on;
		regulator-boot-on;
		regulator-min-microvolt = <3300000>;
		regulator-max-microvolt = <3300000>;
		vin-supply = <&vcc5v0_sys>;
	};

	gpio_keys: gpio-keys {
		compatible = "gpio-keys";
		pinctrl-names = "default";
		pinctrl-0 = <&pwrbtn_pin>;

		key-power {
			debounce-interval = <20>;
			gpios = <&gpio0 RK_PA5 GPIO_ACTIVE_LOW>;
			label = "Power";
			linux,code = <KEY_POWER>;
			wakeup-source;
		};
	};

	gpio_leds: gpio-leds {
		compatible = "gpio-leds";
		pinctrl-names = "default";
		pinctrl-0 = <&sys_led_pin>;

		led-0 {
			label = "green:sys";
			function = LED_FUNCTION_POWER;
			default-state = "on";
			color = <LED_COLOR_ID_GREEN>;
			/* gpio4 RK_PC2 (pin 18) = sys-led-pin */
			gpios = <&gpio4 RK_PC2 GPIO_ACTIVE_HIGH>;
		};
	};

	hdmi_sound: hdmi-sound {
		compatible = "simple-audio-card";
		simple-audio-card,format = "i2s";
		simple-audio-card,mclk-fs = <256>;
		simple-audio-card,name = "hdmi-sound";
		status = "okay";

		simple-audio-card,cpu {
			/* i2s2 at 0xff8a0000 drives HDMI audio */
			sound-dai = <&i2s2>;
		};

		simple-audio-card,codec {
			sound-dai = <&hdmi>;
		};
	};

	/*
	 * virtual-pd0: extcon for DisplayPort hotplug detection.
	 * hpd-gpios: gpio4 RK_PD1 (pin 25) active-low = hpd-en pinctrl.
	 */
	virtual_pd0: virtual-pd0 {
		compatible = "linux,extcon-pd-virtual";
		vpd,init-flip = <0>;
		vpd,init-ss = <0>;
		vpd,init-mode = <2>;
		dp-pwr-supply = <&vcc3v3_dp>;
		hpd-gpios = <&gpio4 RK_PD1 GPIO_ACTIVE_LOW>;
		pinctrl-names = "default";
		pinctrl-0 = <&hpd_en>;
	};
};

&cpu_l0 {
	cpu-supply = <&vdd_cpu_l>;
};

&cpu_l1 {
	cpu-supply = <&vdd_cpu_l>;
};

&cpu_l2 {
	cpu-supply = <&vdd_cpu_l>;
};

&cpu_l3 {
	cpu-supply = <&vdd_cpu_l>;
};

&cpu_b0 {
	cpu-supply = <&vdd_cpu_b>;
};

&cpu_b1 {
	cpu-supply = <&vdd_cpu_b>;
};

&emmc_phy {
	status = "okay";
};

/*
 * GMAC: RGMII Gigabit Ethernet.
 * phy-supply: vcc1v2_phy (PHY 1.2V analog).
 * reset: gpio3 RK_PB7 (pin 15) active-low.
 * tx/rx delay: 0x1e = 30 (from decompiled).
 */
&gmac {
	assigned-clocks = <&cru SCLK_RMII_SRC>;
	assigned-clock-parents = <&clkin_gmac>;
	clock_in_out = "input";
	phy-supply = <&vcc1v2_phy>;
	phy-mode = "rgmii";
	pinctrl-names = "default";
	pinctrl-0 = <&rgmii_pins>;
	snps,reset-gpio = <&gpio3 RK_PB7 GPIO_ACTIVE_LOW>;
	snps,reset-active-low;
	snps,reset-delays-us = <0 10000 50000>;
	snps,txpbl = <4>;
	tx_delay = <0x1e>;
	rx_delay = <0x1e>;
	status = "okay";

	mdio {
		compatible = "snps,dwmac-mdio";
		#address-cells = <1>;
		#size-cells = <0>;

		eth_phy: ethernet-phy@0 {
			compatible = "ethernet-phy-ieee802.3-c22";
			reg = <0>;
		};
	};
};

&gpu {
	mali-supply = <&vdd_gpu>;
	status = "okay";
};

/*
 * HDMI: DW-HDMI controller.
 * Connected to vopb (big VOP) via vopb_out_hdmi endpoint.
 * DDC bus on i2c3. HPD / CEC pins from pinctrl hdmi group.
 */
&hdmi {
	ddc-i2c-bus = <&i2c3>;
	pinctrl-names = "default";
	pinctrl-0 = <&hdmi_i2c_xfer>;
	status = "okay";
};

&hdmi_sound {
	status = "okay";
};

/*
 * I2C0 (PMU domain, 0xff3c0000): PMIC (RK808) + CPU-B/GPU regulators.
 * Clock: 400 kHz; rising/falling times from decompiled i2c-scl-*.
 */
&i2c0 {
	clock-frequency = <400000>;
	i2c-scl-rising-time-ns = <168>;
	i2c-scl-falling-time-ns = <4>;
	status = "okay";

	rk808: pmic@1b {
		compatible = "rockchip,rk808";
		reg = <0x1b>;
		interrupt-parent = <&gpio1>;
		/* gpio1 RK_PC5 (21) active-low = pmic-int-l */
		interrupts = <RK_PC5 IRQ_TYPE_LEVEL_LOW>;
		#clock-cells = <1>;
		clock-output-names = "xin32k", "rk808-clkout2";
		pinctrl-names = "default";
		pinctrl-0 = <&pmic_int_l>;
		rockchip,system-power-controller;
		wakeup-source;

		vcc1-supply = <&vcc_sys>;
		vcc2-supply = <&vcc_sys>;
		vcc3-supply = <&vcc_sys>;
		vcc4-supply = <&vcc_sys>;
		vcc6-supply = <&vcc_sys>;
		vcc7-supply = <&vcc_sys>;
		vcc8-supply = <&vcc3v3_sys>;
		vcc9-supply = <&vcc_sys>;
		vcc10-supply = <&vcc_sys>;
		vcc11-supply = <&vcc_sys>;
		vcc12-supply = <&vcc3v3_sys>;
		vddio-supply = <&vcc_1v8>;

		regulators {
			vdd_center: DCDC_REG1 {
				regulator-name = "vdd_center";
				regulator-always-on;
				regulator-boot-on;
				regulator-min-microvolt = <750000>;
				regulator-max-microvolt = <1350000>;
				regulator-ramp-delay = <6001>;
				regulator-state-mem {
					regulator-off-in-suspend;
				};
			};

			vdd_cpu_l: DCDC_REG2 {
				regulator-name = "vdd_cpu_l";
				regulator-always-on;
				regulator-boot-on;
				regulator-min-microvolt = <750000>;
				regulator-max-microvolt = <1350000>;
				regulator-ramp-delay = <6001>;
				regulator-state-mem {
					regulator-off-in-suspend;
				};
			};

			vcc_ddr: DCDC_REG3 {
				regulator-name = "vcc_ddr";
				regulator-always-on;
				regulator-boot-on;
				regulator-state-mem {
					regulator-on-in-suspend;
				};
			};

			vcc_1v8: DCDC_REG4 {
				regulator-name = "vcc_1v8";
				regulator-always-on;
				regulator-boot-on;
				regulator-min-microvolt = <1800000>;
				regulator-max-microvolt = <1800000>;
				regulator-state-mem {
					regulator-on-in-suspend;
					regulator-suspend-microvolt = <1800000>;
				};
			};

			vcc1v8_dvp: LDO_REG1 {
				regulator-name = "vcc1v8_dvp";
				regulator-boot-on;
				regulator-min-microvolt = <1800000>;
				regulator-max-microvolt = <1800000>;
				regulator-state-mem {
					regulator-off-in-suspend;
				};
			};

			vcc1v8_hdmi: LDO_REG2 {
				regulator-name = "vcc1v8_hdmi";
				regulator-always-on;
				regulator-boot-on;
				regulator-min-microvolt = <1800000>;
				regulator-max-microvolt = <1800000>;
				regulator-state-mem {
					regulator-off-in-suspend;
				};
			};

			vcc1v8_pmu: LDO_REG3 {
				regulator-name = "vcc1v8";
				regulator-always-on;
				regulator-boot-on;
				regulator-min-microvolt = <1800000>;
				regulator-max-microvolt = <1800000>;
				regulator-state-mem {
					regulator-on-in-suspend;
					regulator-suspend-microvolt = <1800000>;
				};
			};

			/* SD card I/O voltage (LDO4) */
			vcc_sd: LDO_REG4 {
				regulator-name = "vcc_sd";
				regulator-always-on;
				regulator-boot-on;
				regulator-min-microvolt = <1800000>;
				regulator-max-microvolt = <3000000>;
				regulator-state-mem {
					regulator-off-in-suspend;
				};
			};

			/* SD card power rail (LDO5) */
			vcc3v0_sd: LDO_REG5 {
				regulator-name = "vcc3v0_sd";
				regulator-always-on;
				regulator-boot-on;
				regulator-min-microvolt = <3000000>;
				regulator-max-microvolt = <3000000>;
				regulator-state-mem {
					regulator-off-in-suspend;
				};
			};

			vcc_1v5: LDO_REG6 {
				regulator-name = "vcc_1v5";
				regulator-always-on;
				regulator-boot-on;
				regulator-min-microvolt = <1500000>;
				regulator-max-microvolt = <1500000>;
				regulator-state-mem {
					regulator-off-in-suspend;
				};
			};

			vcc0v9_hdmi: LDO_REG7 {
				regulator-name = "vcc0v9_hdmi";
				regulator-always-on;
				regulator-boot-on;
				regulator-min-microvolt = <900000>;
				regulator-max-microvolt = <900000>;
				regulator-state-mem {
					regulator-off-in-suspend;
				};
			};

			vcc_3v0: LDO_REG8 {
				regulator-name = "vcc_3v0";
				regulator-always-on;
				regulator-boot-on;
				regulator-min-microvolt = <3000000>;
				regulator-max-microvolt = <3000000>;
				regulator-state-mem {
					regulator-off-in-suspend;
				};
			};

			vcc3v3_s3: SWITCH_REG1 {
				regulator-name = "vcc3v3_s3";
				regulator-always-on;
				regulator-boot-on;
				regulator-state-mem {
					regulator-on-in-suspend;
				};
			};

			vcc3v3_s0: SWITCH_REG2 {
				regulator-name = "vcc3v3_s0";
				regulator-always-on;
				regulator-boot-on;
				regulator-state-mem {
					regulator-on-in-suspend;
				};
			};
		};
	};

	/*
	 * vdd_cpu_b: SYR827 CPU-B voltage regulator.
	 * vsel GPIO: gpio1 RK_PC1 (17) = vsel1-gpio pinctrl.
	 */
	vdd_cpu_b: regulator@40 {
		compatible = "silergy,syr827";
		reg = <0x40>;
		fcs,suspend-voltage-selector = <1>;
		pinctrl-names = "default";
		pinctrl-0 = <&vsel1_gpio>;
		vsel-gpios = <&gpio1 RK_PC1 GPIO_ACTIVE_HIGH>;
		vin-supply = <&vcc_sys>;
		regulator-name = "vdd_cpu_b";
		regulator-min-microvolt = <712500>;
		regulator-max-microvolt = <1500000>;
		regulator-ramp-delay = <1000>;
		regulator-always-on;
		regulator-boot-on;
		regulator-state-mem {
			regulator-off-in-suspend;
		};
	};

	/*
	 * vdd_gpu: SYR828 GPU voltage regulator.
	 * vsel GPIO: gpio1 RK_PB6 (14) = vsel2-gpio pinctrl.
	 */
	vdd_gpu: regulator@41 {
		compatible = "silergy,syr828";
		reg = <0x41>;
		fcs,suspend-voltage-selector = <1>;
		pinctrl-names = "default";
		pinctrl-0 = <&vsel2_gpio>;
		vsel-gpios = <&gpio1 RK_PB6 GPIO_ACTIVE_HIGH>;
		regulator-name = "vdd_gpu";
		regulator-compatible = "fan53555-reg";
		regulator-min-microvolt = <712500>;
		regulator-max-microvolt = <1500000>;
		regulator-ramp-delay = <1000>;
		regulator-always-on;
		regulator-boot-on;
		vin-supply = <&vcc_sys>;
		regulator-state-mem {
			regulator-off-in-suspend;
		};
	};
};

/*
 * I2C4 (PMU domain, 0xff3d0000): PT7C4563 RTC.
 * Interrupt: gpio0 RK_PA6 (6) = pt7c4563-irq pinctrl.
 */
&i2c4 {
	status = "okay";

	hym8563: rtc@51 {
		compatible = "haoyu,hym8563";
		reg = <0x51>;
		#clock-cells = <0>;
		clock-output-names = "xin32k";
		interrupt-parent = <&gpio0>;
		interrupts = <RK_PA6 IRQ_TYPE_LEVEL_LOW>;
		pinctrl-names = "default";
		pinctrl-0 = <&pt7c4563_irq>;
	};
};

/* I2C3: HDMI DDC bus */
&i2c3 {
	i2c-scl-rising-time-ns = <450>;
	i2c-scl-falling-time-ns = <15>;
	status = "okay";
};

/* I2C6: general purpose, connected to 0xff160000 */
&i2c6 {
	status = "okay";
};

&io_domains {
	status = "okay";
	bt656-supply = <&vcc_1v8>;
	audio-supply = <&vcc_1v8>;
	sdmmc-supply = <&vcc_sd>;
	gpio1830-supply = <&vcc_3v0>;
};

&pmu_io_domains {
	status = "okay";
	pmu1830-supply = <&vcc_1v8>;
};

/*
 * PCIe: 4-lane, hosts RTL8822BE WiFi+BT combo card.
 * ep-gpios: gpio0 RK_PB5 (13) from decompiled pcie@f8000000.
 * pci-clkreqn pinctrl uses gpio2 RK_PD2 func-2.
 */
&pcie0 {
	ep-gpios = <&gpio0 RK_PB5 GPIO_ACTIVE_HIGH>;
	num-lanes = <4>;
	pinctrl-names = "default";
	pinctrl-0 = <&pci_clkreqn>;
	vpcie3v3-supply = <&vcc3v3_pcie>;
	status = "okay";
};

/* PWM2: used for backlight or fan control */
&pwm2 {
	status = "okay";
};

/* eMMC: HS400 internal flash */
&sdhci {
	bus-width = <8>;
	mmc-hs400-1_8v;
	mmc-hs400-enhanced-strobe;
	non-removable;
	status = "okay";
};

/*
 * SDIO0 (0xfe310000): disabled on am40; WiFi uses PCIe instead.
 * Left disabled to match original decompiled DTB.
 */
&sdio0 {
	status = "disabled";
};

/*
 * SDMMC (0xfe320000): TF/SD card slot.
 * CD: gpio0 RK_PA7 (7) active-low = sdmmc-cd pinctrl.
 * Power: vcc3v3_baseboard; I/O voltage: vcc_sd (1.8V/3.0V).
 */
&sdmmc {
	bus-width = <4>;
	cap-mmc-highspeed;
	cap-sd-highspeed;
	cd-gpios = <&gpio0 RK_PA7 GPIO_ACTIVE_LOW>;
	disable-wp;
	max-frequency = <50000000>;
	pinctrl-names = "default";
	pinctrl-0 = <&sdmmc_clk &sdmmc_cmd &sdmmc_cd &sdmmc_bus4>;
	vmmc-supply = <&vcc3v3_baseboard>;
	vqmmc-supply = <&vcc_sd>;
	status = "okay";
};

&tcphy0 {
	status = "okay";
};

&tcphy1 {
	status = "okay";
};

&tsadc {
	rockchip,hw-tshut-mode = <1>;
	rockchip,hw-tshut-polarity = <1>;
	status = "okay";
};

/*
 * USB2 PHY0 (OTG, 0xff770000 @ 0xe450):
 * OTG VBUS: gpio1 RK_PC6 (22) = otg-vbus-drv pinctrl.
 * host-port phy-supply: vcc5v0_host.
 */
&u2phy0 {
	status = "okay";
	otg-vbus-gpios = <&gpio1 RK_PC6 GPIO_ACTIVE_HIGH>;

	u2phy0_otg: otg-port {
		status = "okay";
	};

	u2phy0_host: host-port {
		phy-supply = <&vcc5v0_host>;
		status = "okay";
	};
};

/* USB2 PHY1 (0xff770000 @ 0xe460) */
&u2phy1 {
	status = "okay";

	u2phy1_otg: otg-port {
		status = "okay";
	};

	u2phy1_host: host-port {
		phy-supply = <&vcc5v0_host>;
		status = "okay";
	};
};

/*
 * UART0: Bluetooth UART (RTL8822BE BT part).
 * Uses RTS/CTS flow control; RTS GPIO for wakeup via uart0-gpios pinctrl.
 * Clock: rk808 output 1 (32.768 kHz) for BT sleep clock.
 */
&uart0 {
	pinctrl-names = "default";
	pinctrl-0 = <&uart0_xfer &uart0_cts &uart0_rts>;
	status = "okay";

	bluetooth {
		compatible = "realtek,rtl8822bs-bt";
		clocks = <&rk808 1>;
		clock-names = "ext_clock";
		pinctrl-names = "default", "rts_gpio";
		pinctrl-0 = <&uart0_rts>;
		pinctrl-1 = <&uart0_gpios>;
	};
};

/* UART2: serial console */
&uart2 {
	status = "okay";
};

/* USB2 EHCI/OHCI host controllers (fe380000 / fe3a0000 / fe3c0000 / fe3e0000) */
&usb_host0_ehci {
	status = "okay";
};

&usb_host0_ohci {
	status = "okay";
};

&usb_host1_ehci {
	status = "okay";
};

&usb_host1_ohci {
	status = "okay";
};

/* USB3 DRD port 0 (fe800000): Type-C / OTG */
&usbdrd3_0 {
	status = "okay";
};

&usbdrd_dwc3_0 {
	dr_mode = "host";
	extcon = <&u2phy0>;
	status = "okay";
};

/* USB3 DRD port 1 (fe900000): host-only */
&usbdrd3_1 {
	status = "okay";
};

&usbdrd_dwc3_1 {
	dr_mode = "host";
	status = "okay";
};

/* VOP big: primary display (connected to HDMI vopb_out_hdmi) */
&vopb {
	status = "okay";
};

&vopb_mmu {
	status = "okay";
};

/* VOP little: secondary display */
&vopl {
	status = "okay";
};

&vopl_mmu {
	status = "okay";
};

&pinctrl {
	buttons {
		/* gpio0 RK_PA5 (5) pull-up, GPIO = power button */
		pwrbtn_pin: pwrbtn-pin {
			rockchip,pins = <0 RK_PA5 RK_FUNC_GPIO &pcfg_pull_up>;
		};
	};

	eth_phy {
		/* gpio1 RK_PB5 (13) GPIO, controls PHY power */
		eth_phy_pwr: eth-phy-pwr {
			rockchip,pins = <1 RK_PB5 RK_FUNC_GPIO &pcfg_pull_none>;
		};
	};

	hdmi {
		/* gpio4 RK_PD4 (28) output-high = HDMI 5V enable */
		hdmi_5v_drv: hdmi-5v-drv {
			rockchip,pins = <4 RK_PD4 RK_FUNC_GPIO &pcfg_output_high>;
		};
	};

	hpd {
		/* gpio4 RK_PD1 (25) GPIO = DP/HDMI HPD sense */
		hpd_en: hpd-en {
			rockchip,pins = <4 RK_PD1 RK_FUNC_GPIO &pcfg_pull_none>;
		};
	};

	leds {
		/* gpio4 RK_PC2 (18) GPIO = system LED */
		sys_led_pin: sys-led-pin {
			rockchip,pins = <4 RK_PC2 RK_FUNC_GPIO &pcfg_pull_none>;
		};
	};

	pcie {
		/* gpio1 RK_PA4 (4) GPIO = PCIe power enable */
		pcie_drv: pcie-drv {
			rockchip,pins = <1 RK_PA4 RK_FUNC_GPIO &pcfg_pull_none>;
		};

		/* gpio2 RK_PD2 (26) func-2 = PCIe CLKREQN */
		pci_clkreqn: pci-clkreqn {
			rockchip,pins = <2 RK_PD2 2 &pcfg_pull_none>;
		};
	};

	pmic {
		/* gpio1 RK_PC5 (21) pull-up = PMIC interrupt */
		pmic_int_l: pmic-int-l {
			rockchip,pins = <1 RK_PC5 RK_FUNC_GPIO &pcfg_pull_up>;
		};

		/* gpio1 RK_PC1 (17) pull-down = CPU-B vsel */
		vsel1_gpio: vsel1-gpio {
			rockchip,pins = <1 RK_PC1 RK_FUNC_GPIO &pcfg_pull_down>;
		};

		/* gpio1 RK_PB6 (14) pull-down = GPU vsel */
		vsel2_gpio: vsel2-gpio {
			rockchip,pins = <1 RK_PB6 RK_FUNC_GPIO &pcfg_pull_down>;
		};
	};

	pt7c_irq {
		/* gpio0 RK_PA6 (6) pull-up = RTC interrupt */
		pt7c4563_irq: pt7c4563-irq {
			rockchip,pins = <0 RK_PA6 RK_FUNC_GPIO &pcfg_pull_up>;
		};
	};

	usb2 {
		/* gpio1 RK_PA3 (3) GPIO = USB host 5V enable */
		vcc5v0_host_en: vcc5v0-host-en {
			rockchip,pins = <1 RK_PA3 RK_FUNC_GPIO &pcfg_pull_none>;
		};

		/* gpio1 RK_PC6 (22) GPIO = OTG VBUS drive */
		otg_vbus_drv: otg-vbus-drv {
			rockchip,pins = <1 RK_PC6 RK_FUNC_GPIO &pcfg_pull_none>;
		};
	};

	wireless-bluetooth {
		/* gpio2 RK_PC3 (19) GPIO = UART0 RTS as GPIO (BT wakeup) */
		uart0_gpios: uart0-gpios {
			rockchip,pins = <2 RK_PC3 RK_FUNC_GPIO &pcfg_pull_none>;
		};
	};
};
