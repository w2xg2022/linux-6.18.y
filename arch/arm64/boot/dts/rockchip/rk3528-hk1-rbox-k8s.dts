/dts-v1/;

#include <dt-bindings/input/input.h>
#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/pinctrl/rockchip.h>
#include "rk3528.dtsi"

/ {
    model = "RK3528 HK1RBOX K8S Ultimate Edition";
    compatible = "hinlink,hk1rboxk8s", "rockchip,rk3528";

    aliases {
        ethernet0 = &gmac0;
        mmc0 = &sdmmc;
        mmc1 = &sdio1;
        mmc2 = &sdhci;
    };

    chosen {
        stdout-path = "serial0:1500000n8";
    };

    /* --- 1. PMU IO Domains：信号完整性的基石 --- */
    /* 解决 summary 中 voltage 0mV 导致的驱动能力不足及电平抖动 */
    pmu_io_domains: io-domains {
        compatible = "rockchip,rk3528-pmu-io-domain";
        vccio1-supply = <&vcc5v0_sys>;
        vccio2-supply = <&vcc5v0_sys>;
        vccio3-supply = <&vcc5v0_sys>;
        vccio4-supply = <&vcc_sd>;       // SD卡信号域 (3.3V)
        vccio5-supply = <&vcc_1v8_wifi>;  // WiFi IO 域 (1.8V)
        vccio6-supply = <&vcc_sd>;       // SDIO 接口域 (3.3V)
        vccio7-supply = <&vcc5v0_sys>;
        status = "okay";
    };

    /* --- 2. 规范化电源树：解除 WiFi 对 SD 卡检测的依赖 --- */
    vcc5v0_sys: vcc5v0-sys {
        compatible = "regulator-fixed";
        regulator-name = "vcc5v0_sys";
        regulator-always-on;
        regulator-boot-on;
        regulator-min-microvolt = <5000000>;
        regulator-max-microvolt = <5000000>;
    };

    vcc5v0_host: vcc5v0-host {
        compatible = "regulator-fixed";
        enable-active-high;
        gpio = <&gpio0 RK_PA6 GPIO_ACTIVE_HIGH>;
        regulator-name = "vcc5v0_host";
        regulator-always-on;  // 强制开启，不插设备也供电
        regulator-boot-on;    // 启动时立即拉高 GPIO
        vin-supply = <&vcc5v0_sys>;
        regulator-min-microvolt = <5000000>;
        regulator-max-microvolt = <5000000>;
        off-on-delay-us = <20000>;
    };

    vcc_sd: vcc-sd {
        compatible = "regulator-fixed";
        regulator-name = "vcc_sd";
        regulator-min-microvolt = <3300000>;
        regulator-max-microvolt = <3300000>;

        /* 核心修复：强制开启，确保不插 SD 卡时 WiFi 依然有电 */
        regulator-always-on;
        regulator-boot-on;

        enable-active-low;
        gpio = <&gpio4 RK_PA1 GPIO_ACTIVE_LOW>;
        vin-supply = <&vcc5v0_sys>;

        /* 稳定性增强：增加上电缓冲时间 */
        startup-delay-us = <100000>;     // 开启后等待 100ms 待电压稳定
        off-on-delay-us = <20000>;       // 彻底放电间隙
    };

    vcc_1v8_wifi: vcc-1v8-wifi {
        compatible = "regulator-fixed";
        regulator-name = "vcc_1v8_wifi";
        regulator-min-microvolt = <1800000>;
        regulator-max-microvolt = <1800000>;
        regulator-always-on;
        vin-supply = <&vcc5v0_sys>;
    };

    sdio_pwrseq: sdio-pwrseq {
        compatible = "mmc-pwrseq-simple";
        pinctrl-names = "default";
        pinctrl-0 = <&wifi_enable_h &wifi_power_on_h>;
        reset-gpios = <&gpio3 RK_PB4 GPIO_ACTIVE_LOW>;
        post-power-on-delay-ms = <1000>;
        status = "okay";
    };

    /* 复位按键 */
    gpio_keys: gpio-keys {
        compatible = "gpio-keys";
        status = "okay";
        key-factory {
            debounce-interval = <100>;
            gpios = <&gpio4 RK_PB5 GPIO_ACTIVE_LOW>;
            label = "Reset Button";
            linux,code = <KEY_RESTART>;
        };
    };
};

/* --- 3. USB PHY 与控制器 --- */
&u2phy { status = "okay"; };
&u2phy_host { status = "okay"; };
&u2phy_otg { status = "okay"; };

&combphy {
    rockchip,enable-ssc;
    rockchip,u3phy-only;
    phy-supply = <&vcc5v0_host>;
    status = "okay";
};

&usb_host0_xhci {
    dr_mode = "host";
    phys = <&u2phy_otg>, <&combphy PHY_TYPE_USB3>;
    phy-names = "usb2-phy", "usb3-phy";
    vbus-supply = <&vcc5v0_host>;
    snps,dis_u2_susphy_quirk;
    snps,dis_u3_susphy_quirk;
    snps,dis-del-phy-power-on-res-quirk;
    snps,tx-fifo-resize;
    status = "okay";
};

&usb_host0_ehci { status = "okay"; };

/* --- 4. 网络 (GMAC0) --- */
&gmac0 {
    phy-handle = <&rmii0_phy>;
    phy-mode = "rmii";
    status = "okay";
};

&mdio0 {
    status = "okay";
    rmii0_phy: ethernet-phy@2 {
        compatible = "ethernet-phy-ieee802.3-c22";
        reg = <0x2>;
        phy-is-integrated;
        resets = <&cru SRST_MACPHY>;
    };
};

/* --- 5. SDMMC (MicroSD卡槽) --- */
&sdmmc {
    bus-width = <4>;
    vmmc-supply = <&vcc_sd>;
    vqmmc-supply = <&vcc_sd>;
    no-1-8-v;                 // 锁定 3.3V，提高不同品牌 SD 卡的兼容性
    cap-sd-highspeed;
    disable-wp;
    status = "okay";
};

/* --- 6. sdhci (eMMC) --- */
&sdhci {
    bus-width = <8>;
    non-removable;
    status = "okay";
};

/* --- 7. SDIO1 (WiFi 模块) --- */
&sdio1 {
    #address-cells = <1>;
    #size-cells = <0>;
    bus-width = <4>;
    cap-sd-highspeed;
    cap-sdio-irq;
    keep-power-in-suspend;
    non-removable;
    cap-power-off-card;

    mmc-pwrseq = <&sdio_pwrseq>;
    vmmc-supply = <&vcc_sd>;
    vqmmc-supply = <&vcc_1v8_wifi>;

    assigned-clocks = <&cru CCLK_SRC_SDIO1>;
    assigned-clock-parents = <&cru PLL_GPLL>;
    assigned-clock-rates = <100000000>;

    rockchip,default-sample-phase = <90>;
    rockchip,use-v2-tuning;
    status = "okay";

    wifi@1 {
        compatible = "realtek,rtl8733bs";
        reg = <1>;
    };
};

/* --- 8. Pinctrl 增强驱动能力 --- */
&pinctrl {
    sdio1 {
        sdio1_clk: sdio1-clk {
            /* 使用 level-3 驱动等级，增强长距离信号抗干扰 */
            rockchip,pins = <3 RK_PA4 1 &pcfg_pull_up_drv_level_3>;
        };
    };

    wireless-wlan {
        wifi_power_on_h: wifi-power-on-h {
            rockchip,pins = <3 RK_PB2 RK_FUNC_GPIO &pcfg_pull_up>;
        };
        wifi_enable_h: wifi-enable-h {
            rockchip,pins = <3 RK_PB4 RK_FUNC_GPIO &pcfg_pull_up>;
        };
    };
};